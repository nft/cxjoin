{
  "name": "cxjoin",
  "version": "1.0.1",
  "description": "A lightweight utility for conditionally joining classNames together",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts --clean",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nft/cxjoin.git"
  },
  "bugs": {
    "url": "https://github.com/nft/cxjoin/issues"
  },
  "homepage": "https://github.com/nft/cxjoin#readme",
  "keywords": [
    "classnames",
    "clsx",
    "classes",
    "conditionally",
    "classname"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  }
}
